{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "high",
            "reasoningSummary": "detailed"
          }
        }
      }
    }
  },
  "autoupdate": true,
  "default_agent": "plan",
  "enabled_providers": [
    "anthropic",
    "openai"
  ]
}
