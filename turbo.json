{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalEnv": ["TOKENOVERFLOW_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:css": {},
    "format:check": {},
    "preview": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!tests/e2e/**",
        "!public/**",
        "!*.md"
      ],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build", "build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!tests/unit/**",
        "!tests/integration/**",
        "!*.md"
      ],
      "outputs": ["playwright-report/**", "test-results/**"],
      "env": ["CI"]
    },
    "test:lhci": {
      "dependsOn": ["^build", "build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!tests/**",
        "!*.md"
      ],
      "outputs": [".lighthouseci/**"],
      "env": ["CI"]
    }
  }
}
