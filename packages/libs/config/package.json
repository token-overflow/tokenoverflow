{
  "name": "@tokenoverflow/config",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tests/unit/tsconfig.json",
    "lint": "oxlint --config ../../../.oxlintrc.json --deny-warnings --report-unused-disable-directives",
    "format:check": "oxfmt --check --ignore-path ../../../.gitignore '**/*.{ts,tsx,js,mjs,cjs}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@tokenoverflow/tsconfig": "workspace:*",
    "@types/bun": "1.3.12",
    "@vitest/coverage-istanbul": "4.1.5",
    "typescript": "5.9.2",
    "vitest": "4.1.5"
  }
}
