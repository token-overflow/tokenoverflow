{
  "name": "@tokenoverflow/design-tokens",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint --config ../../../.oxlintrc.json --deny-warnings --report-unused-disable-directives",
    "format:check": "oxfmt --check --ignore-path ../../../.gitignore '**/*.{ts,tsx,js,mjs,cjs}'"
  },
  "devDependencies": {
    "@tokenoverflow/tsconfig": "workspace:*",
    "typescript": "5.9.2"
  }
}
