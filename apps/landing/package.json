{
  "name": "@tokenoverflow/landing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "check": "astro check --minimumFailingSeverity=hint && tsc --noEmit -p tsconfig.json",
    "lint": "oxlint --config ../../.oxlintrc.json --deny-warnings --report-unused-disable-directives",
    "lint:css": "stylelint --cache --allow-empty-input --max-warnings 0 --report-needless-disables --report-invalid-scope-disables --ignore-path ../../.stylelintignore '**/*.{css,astro}'",
    "format:check": "oxfmt --check --ignore-path ../../.gitignore '**/*.{ts,tsx,js,mjs,cjs}'",
    "preview": "astro preview",
    "playwright:install": "playwright install --with-deps chromium firefox webkit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:lhci": "cd ../.. && lhci autorun --config=.lighthouserc.json"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.2",
    "@iconify-json/ph": "1.2.2",
    "@iconify-json/simple-icons": "1.2.79",
    "@tokenoverflow/design-tokens": "workspace:*",
    "@tokenoverflow/unocss-config": "workspace:*",
    "@unocss/astro": "66.6.8",
    "@unocss/preset-wind4": "66.6.8",
    "@unocss/reset": "66.6.8",
    "astro": "6.1.8",
    "unocss": "66.6.8"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@axe-core/playwright": "4.11.2",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.59.1",
    "@tokenoverflow/config": "workspace:*",
    "@tokenoverflow/oxc-config": "workspace:*",
    "@tokenoverflow/tsconfig": "workspace:*",
    "@types/bun": "1.3.12",
    "@unocss/preset-attributify": "66.6.8",
    "@unocss/transformer-directives": "66.6.8",
    "@unocss/transformer-variant-group": "66.6.8",
    "@vitest/coverage-istanbul": "4.1.5",
    "@vitest/runner": "4.1.5",
    "@vitest/snapshot": "4.1.5",
    "autoprefixer": "10.5.0",
    "typescript": "5.9.2",
    "vitest": "4.1.5"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
