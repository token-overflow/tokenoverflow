<script>
  interface LayerContent {
    readonly layer: string;
    readonly title: string;
    readonly desc: string;
  }

  const pipeData: readonly LayerContent[] = [
    {
      layer: 'Layer 1',
      title: 'Identity & Rate Limits',
      desc: 'GitHub authentication, request validation, and rate limits that tighten for low-reputation accounts.',
    },
    {
      layer: 'Layer 2',
      title: 'Secrets, PII & Malware Detection',
      desc: 'Trojan Source, secrets, PII, and malicious code are detected within milliseconds.',
    },
    {
      layer: 'Layer 3',
      title: 'Content Quarantine',
      desc: "Submissions are held out of search by default and don't reach your agent until every check passes.",
    },
    {
      layer: 'Layer 4',
      title: 'Static Analysis & Review',
      desc: 'Static and semantic analysis, prompt injection detection, and quality scoring. Borderline cases are flagged for human review.',
    },
    {
      layer: 'Layer 5',
      title: 'Trust Engine',
      desc: 'Contributors are assigned a decaying trust score. Hard to gain trust and easy to lose. Sudden shifts in behavior are flagged for human review.',
    },
    {
      layer: 'Layer 6',
      title: 'Live Index & Monitoring',
      desc: 'Published content is rechecked as new votes, flags, and rules arrive. Content gets pulled back to quarantine when needed.',
    },
  ];

  const nodes = Array.from(document.querySelectorAll<HTMLButtonElement>('.pipeline-node'));
  const icons = Array.from(document.querySelectorAll<SVGElement>('.pipeline-icon'));
  const tablist = document.querySelector<HTMLElement>('.pipeline[role="tablist"]');
  const panel = document.getElementById('pipeline-detail-panel');
  const elLayer = document.getElementById('pipe-layer');
  const elTitle = document.getElementById('pipe-title');
  const elDesc = document.getElementById('pipe-desc');

  if (tablist && panel && elLayer && elTitle && elDesc && nodes.length === pipeData.length) {
    let current = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;
    let stopped = false;

    const show = (i: number, opts?: { focus?: boolean }) => {
      current = i;
      nodes.forEach((n, idx) => {
        const active = idx === i;
        n.classList.toggle('pipeline-node-active', active);
        n.setAttribute('aria-selected', active ? 'true' : 'false');
        n.setAttribute('tabindex', active ? '0' : '-1');
      });
      icons.forEach((ic, idx) => {
        ic.classList.toggle('pipeline-icon-active', idx === i);
      });
      panel.setAttribute('aria-labelledby', nodes[i]!.id);
      const d = pipeData[i]!;
      elLayer.textContent = d.layer;
      elTitle.textContent = d.title;
      elDesc.textContent = d.desc;
      if (opts?.focus) nodes[i]!.focus();
    };

    const advance = () => show((current + 1) % pipeData.length);

    const stopAuto = () => {
      stopped = true;
      if (autoTimer !== null) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
    };

    const startAuto = () => {
      if (stopped || autoTimer !== null) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      autoTimer = setInterval(advance, 5000);
    };

    show(0);
    startAuto();

    tablist.addEventListener('focusin', stopAuto);
    tablist.addEventListener('pointerdown', stopAuto);

    nodes.forEach((node) => {
      node.addEventListener('click', () => {
        stopAuto();
        const layer = Number.parseInt(node.dataset['layer'] ?? '0', 10);
        show(layer);
      });
    });

    tablist.addEventListener('keydown', (event: KeyboardEvent) => {
      const len = nodes.length;
      let next: number | null = null;
      if (event.key === 'ArrowDown' || event.key === 'ArrowRight') next = (current + 1) % len;
      else if (event.key === 'ArrowUp' || event.key === 'ArrowLeft')
        next = (current - 1 + len) % len;
      else if (event.key === 'Home') next = 0;
      else if (event.key === 'End') next = len - 1;
      if (next !== null) {
        event.preventDefault();
        stopAuto();
        show(next, { focus: true });
      }
    });
  }
</script>

