---
// Vertical pipeline tablist: six layers, one detail panel. Follows WAI-ARIA
// Authoring Practices for tab pattern (click, Arrow keys, Home/End).
// Auto-advances until the user interacts; permanently stops afterwards.
// Under prefers-reduced-motion the auto-advance timer is not started.
const layers = [
  { key: 'gate', label: 'Layer 1', title: 'Gate' },
  { key: 'scan', label: 'Layer 2', title: 'Scan' },
  { key: 'quarantine', label: 'Layer 3', title: 'Quarantine' },
  { key: 'analyze', label: 'Layer 4', title: 'Analyze' },
  { key: 'trust', label: 'Layer 5', title: 'Trust' },
  { key: 'monitor', label: 'Layer 6', title: 'Monitor' },
];
---

<div
  class="pipeline-layout grid gap-20 md:grid-cols-[auto_minmax(0,26rem)] justify-center max-w-[52rem] mx-auto max-md:gap-8"
  data-fade-in
>
  <div
    class="pipeline relative py-4 flex flex-col overflow-hidden"
    role="tablist"
    aria-label="Security pipeline layers"
    aria-orientation="vertical"
  >
    <div class="pipeline-endpoint pipeline-endpoint-start relative flex items-center gap-3 pl-14 w-full pb-3">
      <span
        class="pipeline-endpoint-text text-micro font-mono font-semibold tracking-[0.08em] uppercase text-neutral-500"
        >Submission</span
      >
    </div>

    {
      layers.map((layer, index) => (
        <button
          type="button"
          class:list={[
            'pipeline-node relative pl-14 py-3 w-full cursor-pointer bg-none border-none font-sans text-start touch-manipulation',
            index === 0 && 'pipeline-node-active',
            'focus-ring',
          ]}
          data-layer={index}
          role="tab"
          id={`pipeline-tab-${index}`}
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls="pipeline-detail-panel"
          tabindex={index === 0 ? 0 : -1}
        >
          <span class="pipeline-dot absolute left-2 top-3.5 w-6 h-6 rounded-full border-2 border-neutral-200 bg-white flex items-center justify-center z-1 transition-[border-color,background,transform] duration-300">
            <span class="pipeline-dot-inner w-2 h-2 rounded-full bg-neutral-200 transition-[background,transform] duration-300" />
          </span>
          <span class="pipeline-node-label text-micro block font-mono font-semibold text-neutral-500 tracking-wider uppercase mb-1 transition-colors duration-300">
            {layer.label}
          </span>
          <span class="pipeline-node-title block text-sm font-bold transition-colors duration-300">
            {layer.title}
          </span>
        </button>
      ))
    }

    <div class="pipeline-endpoint pipeline-endpoint-end relative flex items-center gap-3 pl-14 w-full pt-3">
      <span
        class="pipeline-endpoint-text text-micro font-mono font-semibold tracking-[0.08em] uppercase text-green-500"
        >Published</span
      >
    </div>
  </div>

  <div
    class="pipeline-detail sticky top-24"
    id="pipeline-detail-panel"
    role="tabpanel"
    aria-labelledby="pipeline-tab-0"
    aria-live="polite"
